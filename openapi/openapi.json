{
  "components": {
    "schemas": {
      "AcceptedHypothesisResponse": {
        "additionalProperties": false,
        "description": "One persisted teacher-visible accepted hypothesis.",
        "properties": {
          "description": {
            "title": "Description",
            "type": "string"
          },
          "evidence_refs": {
            "items": {
              "type": "string"
            },
            "title": "Evidence Refs",
            "type": "array"
          },
          "rank": {
            "title": "Rank",
            "type": "integer"
          },
          "template_id": {
            "title": "Template Id",
            "type": "string"
          },
          "truth_table_hash": {
            "title": "Truth Table Hash",
            "type": "string"
          }
        },
        "required": [
          "template_id",
          "evidence_refs",
          "description",
          "rank",
          "truth_table_hash"
        ],
        "title": "AcceptedHypothesisResponse",
        "type": "object"
      },
      "AnalysisRequest": {
        "additionalProperties": false,
        "description": "CAS input for an analysis command.",
        "properties": {
          "expected_version": {
            "default": 0,
            "minimum": 0.0,
            "title": "Expected Version",
            "type": "integer"
          }
        },
        "title": "AnalysisRequest",
        "type": "object"
      },
      "AnswerConstraints": {
        "additionalProperties": false,
        "description": "Strict numeric bounds disclosed to a learner.",
        "properties": {
          "maximum": {
            "const": 10000,
            "default": 10000,
            "title": "Maximum",
            "type": "integer"
          },
          "minimum": {
            "const": -10000,
            "default": -10000,
            "title": "Minimum",
            "type": "integer"
          }
        },
        "title": "AnswerConstraints",
        "type": "object"
      },
      "AuditEventResponse": {
        "additionalProperties": false,
        "description": "One append-only transition event.",
        "properties": {
          "from_state": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "From State"
          },
          "occurred_at": {
            "format": "date-time",
            "title": "Occurred At",
            "type": "string"
          },
          "sequence": {
            "title": "Sequence",
            "type": "integer"
          },
          "to_state": {
            "title": "To State",
            "type": "string"
          },
          "version": {
            "title": "Version",
            "type": "integer"
          }
        },
        "required": [
          "sequence",
          "from_state",
          "to_state",
          "version",
          "occurred_at"
        ],
        "title": "AuditEventResponse",
        "type": "object"
      },
      "AuditResponse": {
        "additionalProperties": false,
        "description": "Complete transition readback for one owned workflow.",
        "properties": {
          "events": {
            "items": {
              "$ref": "#/components/schemas/AuditEventResponse"
            },
            "title": "Events",
            "type": "array"
          },
          "workflow_id": {
            "format": "uuid",
            "title": "Workflow Id",
            "type": "string"
          }
        },
        "required": [
          "workflow_id",
          "events"
        ],
        "title": "AuditResponse",
        "type": "object"
      },
      "CompiledProbeResponse": {
        "additionalProperties": false,
        "description": "The persisted deterministic probe specification shown only to teachers.",
        "properties": {
          "compiler_version": {
            "title": "Compiler Version",
            "type": "string"
          },
          "correct_prediction": {
            "title": "Correct Prediction",
            "type": "integer"
          },
          "original_problem": {
            "$ref": "#/components/schemas/SignedProblemDTO"
          },
          "predictions": {
            "items": {
              "$ref": "#/components/schemas/ProbePredictionResponse"
            },
            "title": "Predictions",
            "type": "array"
          },
          "problem": {
            "$ref": "#/components/schemas/SignedProblemDTO"
          },
          "proof": {
            "$ref": "#/components/schemas/CompilerSearchProof"
          },
          "registry_version": {
            "title": "Registry Version",
            "type": "string"
          },
          "specification_hash": {
            "title": "Specification Hash",
            "type": "string"
          }
        },
        "required": [
          "original_problem",
          "problem",
          "correct_prediction",
          "specification_hash",
          "registry_version",
          "compiler_version",
          "predictions",
          "proof"
        ],
        "title": "CompiledProbeResponse",
        "type": "object"
      },
      "CompilerCandidateProof": {
        "additionalProperties": false,
        "description": "One ranked separating candidate exposed to the authorized teacher.",
        "properties": {
          "correct_result_magnitude": {
            "maximum": 24.0,
            "minimum": 0.0,
            "title": "Correct Result Magnitude",
            "type": "integer"
          },
          "distinct_output_count": {
            "minimum": 2.0,
            "title": "Distinct Output Count",
            "type": "integer"
          },
          "distinguished_pair_count": {
            "minimum": 1.0,
            "title": "Distinguished Pair Count",
            "type": "integer"
          },
          "operand_magnitude": {
            "maximum": 24.0,
            "minimum": 0.0,
            "title": "Operand Magnitude",
            "type": "integer"
          },
          "predictions": {
            "items": {
              "type": "integer"
            },
            "minItems": 2,
            "title": "Predictions",
            "type": "array"
          },
          "problem": {
            "$ref": "#/components/schemas/SignedProblemDTO"
          },
          "rank": {
            "maximum": 5.0,
            "minimum": 1.0,
            "title": "Rank",
            "type": "integer"
          },
          "top_two_separated": {
            "title": "Top Two Separated",
            "type": "boolean"
          }
        },
        "required": [
          "problem",
          "predictions",
          "distinct_output_count",
          "top_two_separated",
          "distinguished_pair_count",
          "operand_magnitude",
          "correct_result_magnitude",
          "rank"
        ],
        "title": "CompilerCandidateProof",
        "type": "object"
      },
      "CompilerSearchProof": {
        "additionalProperties": false,
        "description": "Complete bounded-domain counts and up to five deterministic finalists.",
        "properties": {
          "chosen_candidate_rank": {
            "const": 1,
            "title": "Chosen Candidate Rank",
            "type": "integer"
          },
          "domain_problem_count": {
            "const": 625,
            "title": "Domain Problem Count",
            "type": "integer"
          },
          "eligible_candidate_count": {
            "const": 624,
            "title": "Eligible Candidate Count",
            "type": "integer"
          },
          "separating_candidate_count": {
            "maximum": 624.0,
            "minimum": 1.0,
            "title": "Separating Candidate Count",
            "type": "integer"
          },
          "top_candidates": {
            "items": {
              "$ref": "#/components/schemas/CompilerCandidateProof"
            },
            "maxItems": 5,
            "minItems": 1,
            "title": "Top Candidates",
            "type": "array"
          }
        },
        "required": [
          "domain_problem_count",
          "eligible_candidate_count",
          "separating_candidate_count",
          "chosen_candidate_rank",
          "top_candidates"
        ],
        "title": "CompilerSearchProof",
        "type": "object"
      },
      "CreateCaseRequest": {
        "additionalProperties": false,
        "description": "A de-identified teacher case without learner identity fields.",
        "properties": {
          "deidentified_attestation": {
            "default": false,
            "title": "Deidentified Attestation",
            "type": "boolean"
          },
          "observed_work": {
            "maxLength": 10000,
            "minLength": 1,
            "title": "Observed Work",
            "type": "string"
          },
          "problem": {
            "$ref": "#/components/schemas/SignedProblemDTO"
          },
          "source_tier": {
            "enum": [
              "authentic",
              "synthetic",
              "mixed",
              "published_exemplar",
              "educator_authored",
              "custom"
            ],
            "title": "Source Tier",
            "type": "string"
          }
        },
        "required": [
          "source_tier",
          "problem",
          "observed_work"
        ],
        "title": "CreateCaseRequest",
        "type": "object"
      },
      "CreateCaseResponse": {
        "additionalProperties": false,
        "description": "Opaque identifiers for the newly owned case and workflow.",
        "properties": {
          "case_id": {
            "format": "uuid",
            "title": "Case Id",
            "type": "string"
          },
          "workflow_id": {
            "format": "uuid",
            "title": "Workflow Id",
            "type": "string"
          }
        },
        "required": [
          "case_id",
          "workflow_id"
        ],
        "title": "CreateCaseResponse",
        "type": "object"
      },
      "EvidenceStatusResponse": {
        "additionalProperties": false,
        "description": "One deterministic status from the closed evidence vocabulary.",
        "properties": {
          "rank": {
            "title": "Rank",
            "type": "integer"
          },
          "status": {
            "enum": [
              "supported",
              "weakened",
              "unresolved",
              "abstained"
            ],
            "title": "Status",
            "type": "string"
          },
          "template_id": {
            "title": "Template Id",
            "type": "string"
          }
        },
        "required": [
          "template_id",
          "rank",
          "status"
        ],
        "title": "EvidenceStatusResponse",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "LearnerProbeResponse": {
        "additionalProperties": false,
        "description": "Deliberately minimal learner-facing DTO.",
        "properties": {
          "answer_constraints": {
            "$ref": "#/components/schemas/AnswerConstraints"
          },
          "expires_at": {
            "format": "date-time",
            "title": "Expires At",
            "type": "string"
          },
          "instructions": {
            "const": "Submit one signed integer.",
            "default": "Submit one signed integer.",
            "title": "Instructions",
            "type": "string"
          },
          "problem": {
            "$ref": "#/components/schemas/SignedProblemDTO"
          }
        },
        "required": [
          "problem",
          "answer_constraints",
          "expires_at"
        ],
        "title": "LearnerProbeResponse",
        "type": "object"
      },
      "LearnerReceiptResponse": {
        "additionalProperties": false,
        "description": "Content-minimal receipt for the accepted response.",
        "properties": {
          "accepted_at": {
            "format": "date-time",
            "title": "Accepted At",
            "type": "string"
          },
          "receipt_id": {
            "format": "uuid",
            "title": "Receipt Id",
            "type": "string"
          }
        },
        "required": [
          "receipt_id",
          "accepted_at"
        ],
        "title": "LearnerReceiptResponse",
        "type": "object"
      },
      "LearnerSubmitRequest": {
        "additionalProperties": false,
        "description": "Strict one-answer learner submission.",
        "properties": {
          "answer": {
            "maximum": 10000.0,
            "minimum": -10000.0,
            "title": "Answer",
            "type": "integer"
          },
          "rationale": {
            "anyOf": [
              {
                "maxLength": 1000,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Rationale"
          }
        },
        "required": [
          "answer"
        ],
        "title": "LearnerSubmitRequest",
        "type": "object"
      },
      "LearnerTokenResponse": {
        "additionalProperties": false,
        "description": "Teacher decision result with a capability only when the probe is approved.",
        "properties": {
          "expires_at": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Expires At"
          },
          "response_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Response Url"
          },
          "workflow": {
            "$ref": "#/components/schemas/WorkflowResponse"
          }
        },
        "required": [
          "response_url",
          "expires_at",
          "workflow"
        ],
        "title": "LearnerTokenResponse",
        "type": "object"
      },
      "OwnerBootstrapResponse": {
        "additionalProperties": false,
        "description": "Privacy-safe signal that an owner session exists before mutation.",
        "properties": {
          "detail": {
            "const": "owner session initialized; retry the exact command",
            "default": "owner session initialized; retry the exact command",
            "title": "Detail",
            "type": "string"
          }
        },
        "title": "OwnerBootstrapResponse",
        "type": "object"
      },
      "ProbeApprovalRequest": {
        "additionalProperties": false,
        "description": "Teacher decision at the first workflow interrupt.",
        "properties": {
          "approved": {
            "title": "Approved",
            "type": "boolean"
          },
          "expected_version": {
            "minimum": 0.0,
            "title": "Expected Version",
            "type": "integer"
          },
          "expires_in_seconds": {
            "default": 86400,
            "maximum": 604800.0,
            "minimum": 60.0,
            "title": "Expires In Seconds",
            "type": "integer"
          }
        },
        "required": [
          "expected_version",
          "approved"
        ],
        "title": "ProbeApprovalRequest",
        "type": "object"
      },
      "ProbePredictionResponse": {
        "additionalProperties": false,
        "description": "One persisted alternative prediction committed with the probe.",
        "properties": {
          "prediction": {
            "title": "Prediction",
            "type": "integer"
          },
          "rank": {
            "title": "Rank",
            "type": "integer"
          },
          "template_id": {
            "title": "Template Id",
            "type": "string"
          }
        },
        "required": [
          "template_id",
          "rank",
          "prediction"
        ],
        "title": "ProbePredictionResponse",
        "type": "object"
      },
      "ReviewRequest": {
        "additionalProperties": false,
        "description": "Teacher decision at the final workflow interrupt.",
        "properties": {
          "decision": {
            "enum": [
              "approved",
              "edited",
              "rejected",
              "abstained"
            ],
            "title": "Decision",
            "type": "string"
          },
          "edited_text": {
            "anyOf": [
              {
                "maxLength": 8000,
                "minLength": 1,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Edited Text"
          },
          "expected_version": {
            "minimum": 0.0,
            "title": "Expected Version",
            "type": "integer"
          },
          "note": {
            "anyOf": [
              {
                "maxLength": 4000,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Note"
          }
        },
        "required": [
          "expected_version",
          "decision"
        ],
        "title": "ReviewRequest",
        "type": "object"
      },
      "ReviewResultResponse": {
        "additionalProperties": false,
        "description": "The persisted final teacher decision and separately stored edit.",
        "properties": {
          "created_at": {
            "format": "date-time",
            "title": "Created At",
            "type": "string"
          },
          "decision": {
            "enum": [
              "approved",
              "edited",
              "rejected",
              "abstained"
            ],
            "title": "Decision",
            "type": "string"
          },
          "edited_text": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Edited Text"
          },
          "note": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Note"
          }
        },
        "required": [
          "decision",
          "note",
          "edited_text",
          "created_at"
        ],
        "title": "ReviewResultResponse",
        "type": "object"
      },
      "SignedProblemDTO": {
        "additionalProperties": false,
        "description": "One signed-subtraction problem in the frozen compiler domain.",
        "properties": {
          "a": {
            "maximum": 12.0,
            "minimum": -12.0,
            "title": "A",
            "type": "integer"
          },
          "b": {
            "maximum": 12.0,
            "minimum": -12.0,
            "title": "B",
            "type": "integer"
          }
        },
        "required": [
          "a",
          "b"
        ],
        "title": "SignedProblemDTO",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      },
      "VersionResponse": {
        "additionalProperties": false,
        "description": "Public build and deterministic-contract versions.",
        "properties": {
          "compiler_version": {
            "title": "Compiler Version",
            "type": "string"
          },
          "registry_version": {
            "title": "Registry Version",
            "type": "string"
          },
          "schema_version": {
            "title": "Schema Version",
            "type": "string"
          },
          "version": {
            "title": "Version",
            "type": "string"
          }
        },
        "required": [
          "version",
          "schema_version",
          "registry_version",
          "compiler_version"
        ],
        "title": "VersionResponse",
        "type": "object"
      },
      "WorkflowResponse": {
        "additionalProperties": false,
        "description": "Teacher-facing workflow snapshot with reproducibility metadata.",
        "properties": {
          "accepted_hypotheses": {
            "items": {
              "$ref": "#/components/schemas/AcceptedHypothesisResponse"
            },
            "title": "Accepted Hypotheses",
            "type": "array"
          },
          "case_id": {
            "format": "uuid",
            "title": "Case Id",
            "type": "string"
          },
          "compiled_probe": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/CompiledProbeResponse"
              },
              {
                "type": "null"
              }
            ]
          },
          "compiler_version": {
            "title": "Compiler Version",
            "type": "string"
          },
          "created_at": {
            "format": "date-time",
            "title": "Created At",
            "type": "string"
          },
          "deterministic_evidence": {
            "items": {
              "$ref": "#/components/schemas/EvidenceStatusResponse"
            },
            "title": "Deterministic Evidence",
            "type": "array"
          },
          "edited_text": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Edited Text"
          },
          "generated_proposal": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Generated Proposal"
          },
          "learner_response_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Learner Response Url"
          },
          "model_request_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Model Request Id"
          },
          "model_snapshot": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Model Snapshot"
          },
          "prompt_version": {
            "title": "Prompt Version",
            "type": "string"
          },
          "registry_version": {
            "title": "Registry Version",
            "type": "string"
          },
          "review_result": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ReviewResultResponse"
              },
              {
                "type": "null"
              }
            ]
          },
          "schema_version": {
            "title": "Schema Version",
            "type": "string"
          },
          "source_tier": {
            "enum": [
              "authentic",
              "synthetic",
              "mixed",
              "published_exemplar",
              "educator_authored",
              "custom"
            ],
            "title": "Source Tier",
            "type": "string"
          },
          "state": {
            "title": "State",
            "type": "string"
          },
          "updated_at": {
            "format": "date-time",
            "title": "Updated At",
            "type": "string"
          },
          "version": {
            "title": "Version",
            "type": "integer"
          },
          "workflow_id": {
            "format": "uuid",
            "title": "Workflow Id",
            "type": "string"
          }
        },
        "required": [
          "workflow_id",
          "case_id",
          "source_tier",
          "state",
          "schema_version",
          "registry_version",
          "prompt_version",
          "compiler_version",
          "model_snapshot",
          "model_request_id",
          "learner_response_url",
          "created_at",
          "updated_at",
          "version",
          "accepted_hypotheses",
          "compiled_probe",
          "deterministic_evidence",
          "review_result"
        ],
        "title": "WorkflowResponse",
        "type": "object"
      }
    }
  },
  "info": {
    "title": "COGNISECT API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/health": {
      "get": {
        "operationId": "health_route_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "title": "Response Health Route Health Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Health Route"
      }
    },
    "/v1/cases": {
      "post": {
        "operationId": "create_case_route_v1_cases_post",
        "parameters": [
          {
            "in": "header",
            "name": "Idempotency-Key",
            "required": true,
            "schema": {
              "maxLength": 200,
              "minLength": 8,
              "pattern": "^[\\x21-\\x7e]+$",
              "title": "Idempotency-Key",
              "type": "string"
            }
          },
          {
            "in": "cookie",
            "name": "cognisect_owner",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Cognisect Owner"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCaseRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
